# Configuration locale pour développement avec PostgreSQL
# Copiez ce fichier en .env.local et modifiez les valeurs

APP_NAME="Portfolio QHE"
APP_ENV=local
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=true
APP_URL=http://localhost:8000

# PostgreSQL (pour tester la configuration production)
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=portfolio_dev
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SSLMODE=prefer

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password123

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Session
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
